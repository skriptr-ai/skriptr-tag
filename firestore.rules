rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Any authenticated @skriptr user can read other profiles to display names/colors in multiplayer lobbies
      allow read: if request.auth != null && 
                   request.auth.token.email.matches('.*@skriptr\\..*');
                   
      // Only the user themselves can write to their profile document
      allow write: if request.auth != null && 
                    request.auth.uid == userId && 
                    request.auth.token.email.matches('.*@skriptr\\..*');
    }
  }
}
